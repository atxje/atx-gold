generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// NextAuth.js required models
model Account {
  id                String    @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?   @db.Text
  access_token      String?   @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?   @db.Text
  session_state     String?
  lastEmailScanAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Application models
model Customer {
  id             String   @id @default(cuid())
  name           String
  address        String?
  phone          String?
  contactPerson  String?
  salesTax       Boolean  @default(false)

  invoices Invoice[]
  memos    Memo[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts     Account[]
  sessions     Session[]
  leads        Lead[]
  appointments Appointment[]
  purchases    Purchase[]
}

enum LeadSource {
  ORGANIC
  PAID
}

enum LeadChannel {
  ONLINE_FORM
  PHONE
  TEXT
  WALK_IN
}

enum LeadStatus {
  NEW
  CONTACTED
  APPOINTMENT_SET
  MET
  BOUGHT
  NO_SALE
}

model Lead {
  id           String      @id @default(cuid())
  name         String
  phone        String?
  email        String?
  notes        String?     @db.Text
  source       LeadSource  @default(ORGANIC)
  channel      LeadChannel @default(PHONE)
  status       LeadStatus  @default(NEW)
  followUpDate DateTime?

  createdById String
  createdBy   User     @relation(fields: [createdById], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  appointments     Appointment[]
  purchases        Purchase[]
  smsConversations SmsConversation[]

  @@index([status])
  @@index([followUpDate])
  @@index([createdById])
}

model Appointment {
  id                    String   @id @default(cuid())
  leadId                String
  userId                String
  dateTime              DateTime
  duration              Int      @default(30) // in minutes
  location              String?
  notes                 String?  @db.Text
  googleCalendarEventId String?

  lead User @relation(fields: [userId], references: [id])
  leadRelation Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([userId])
  @@index([dateTime])
}

enum MetalType {
  GOLD
  SILVER
  PLATINUM
  PALLADIUM
  DIAMOND
  JEWELRY
  WATCH
  OTHER
}

enum WeightUnit {
  GRAM
  TROY_OZ
  CARAT
}

enum InventoryStatus {
  ON_STOCK
  OUT_ON_MEMO
}

model InventoryItem {
  id               String          @id @default(cuid())
  itemCode         String?         @unique
  category         String
  subcategory      String
  name             String
  weightUnit       WeightUnit      @default(GRAM)
  totalWeight      Float           @default(0)
  availableWeight  Float           @default(0)
  totalCost        Float           @default(0)
  soldWeight       Float           @default(0)
  soldValue        Float           @default(0)
  totalProfit      Float           @default(0)
  askingPrice      Float           @default(0)
  quantity         Int             @default(0)
  status           InventoryStatus @default(ON_STOCK)

  purchases        Purchase[]
  invoiceItems     InvoiceItem[]
  memoItems        MemoItem[]
  mixTransferItems MixTransferItem[]
  diamondDetails   DiamondDetails?
  jewelryDetails   JewelryDetails?
  watchDetails     WatchDetails?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([category, subcategory])
}

model DiamondDetails {
  id              String  @id @default(cuid())
  inventoryItemId String  @unique
  shape           String? // Round, Princess, Cushion, Oval, Emerald, Pear, Marquise, Radiant, Asscher, Heart
  caratWeight     Float?
  color           String? // D-Z or Fancy
  clarity         String? // FL, IF, VVS1, VVS2, VS1, VS2, SI1, SI2, I1, I2, I3
  lab             String? // GIA, AGS, IGI, EGL, HRD, None
  certNumber      String?
  cutGrade        String? // Excellent, Very Good, Good, Fair, Poor
  polish          String? // Excellent, Very Good, Good, Fair, Poor
  symmetry        String? // Excellent, Very Good, Good, Fair, Poor
  fluorescence    String? // None, Faint, Medium, Strong, Very Strong
  measurements    String? // e.g. "6.5 x 6.5 x 4.0"
  costPerCarat    Float?
  rapPrice        Float?  // Rapaport list price per carat
  rapDiscount     Float?  // Discount % from Rap
  notes           String? @db.Text

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model JewelryDetails {
  id              String  @id @default(cuid())
  inventoryItemId String  @unique
  metal           String? // Sterling, 10K, 14K, 18K, Plat
  brand           String? // T&Co, DY, JA, Cartier, VCA, Other
  mainStone       String? // Diamond, Sapphire, Ruby, Tanzanite, Topaz, Other, None
  costPerGram     Float?
  description     String?

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model WatchDetails {
  id              String  @id @default(cuid())
  inventoryItemId String  @unique
  brand           String? // Rolex, Cartier, Omega, AP, Patek, etc.
  referenceNumber String?
  serialNumber    String?
  caseMetal       String? // SS, Gold, Platinum
  caseSizeMM      String? // 26mm, 36mm, 40mm, etc.
  box             Boolean @default(false)
  paperwork       Boolean @default(false)
  description     String?

  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MixTransfer {
  id        String            @id @default(cuid())
  createdAt DateTime          @default(now())
  note      String?
  items     MixTransferItem[]
}

model MixTransferItem {
  id              String        @id @default(cuid())
  mixTransferId   String
  inventoryItemId String
  weight          Float
  totalCost       Float
  role            String        // "SOURCE" or "DEST"

  mixTransfer   MixTransfer   @relation(fields: [mixTransferId], references: [id])
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
}

enum InvoiceType {
  SALE
  TRANSFER
}

enum MemoStatus {
  ACTIVE
  RETURNED
  CONVERTED
}

model Invoice {
  id            String        @id @default(cuid())
  invoiceNumber String        @unique
  invoiceType   InvoiceType   @default(SALE)
  customerId    String?
  buyerName     String
  buyerEmail    String?
  buyerPhone    String?
  buyerAddress  String?
  date          DateTime      @default(now())
  totalAmount   Float
  notes         String?       @db.Text

  customer  Customer?     @relation(fields: [customerId], references: [id])
  items     InvoiceItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InvoiceItem {
  id              String        @id @default(cuid())
  invoiceId       String
  inventoryItemId String
  description     String
  weight          Float
  weightUnit      WeightUnit
  pricePerUnit    Float
  totalPrice      Float
  costBasis       Float         @default(0)
  profit          Float         @default(0)
  quantity        Int           @default(0)
  memoItemId      String?       @unique

  invoice       Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
  memoItem      MemoItem?     @relation(fields: [memoItemId], references: [id])
}

model Memo {
  id            String     @id @default(cuid())
  memoNumber    String     @unique
  customerId    String?
  customerName  String
  customerEmail String?
  customerPhone String?
  memoDate      DateTime   @default(now())
  returnDate    DateTime
  status        MemoStatus @default(ACTIVE)
  totalValue    Float
  notes         String?    @db.Text

  customer  Customer?  @relation(fields: [customerId], references: [id])
  items     MemoItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MemoItem {
  id              String     @id @default(cuid())
  memoId          String
  inventoryItemId String
  description     String
  weight          Float
  weightUnit      WeightUnit
  pricePerUnit    Float
  totalValue      Float
  quantity        Int        @default(0)
  status          MemoStatus @default(ACTIVE)

  memo          Memo          @relation(fields: [memoId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id])
  invoiceItem   InvoiceItem?
}

model Purchase {
  id              String     @id @default(cuid())
  leadId          String
  userId          String
  description     String
  metalType       MetalType
  weight          Float
  weightUnit      WeightUnit @default(GRAM)
  purity          String?
  pricePaid       Float
  pricePerUnit    Float?
  quantity        Int            @default(0)
  category        String?
  subcategory     String?
  inventoryItemId String?
  purchaseNumber  String?
  purchaseDate    DateTime   @default(now())
  notes           String?    @db.Text
  paymentMethod   String?    @db.Text

  lead          Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id])
  inventoryItem InventoryItem? @relation(fields: [inventoryItemId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([userId])
  @@index([purchaseDate])
  @@index([inventoryItemId])
}

enum ConversationStatus {
  ACTIVE
  COMPLETED
  PAUSED
}

model SmsConversation {
  id          String             @id @default(cuid())
  leadId      String
  status      ConversationStatus @default(ACTIVE)
  startedAt   DateTime           @default(now())
  completedAt DateTime?

  lead     Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  messages SmsMessage[]

  @@index([leadId])
  @@index([status])
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

model SmsMessage {
  id             String           @id @default(cuid())
  conversationId String
  direction      MessageDirection
  content        String           @db.Text
  sentAt         DateTime         @default(now())
  twilioSid      String?

  conversation SmsConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([sentAt])
}

model StockCategory {
  id            String             @id @default(cuid())
  name          String             @unique
  metalType     MetalType          @default(GOLD)
  weightUnit    WeightUnit         @default(GRAM)
  sortOrder     Int                @default(0)
  subcategories StockSubcategory[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StockSubcategory {
  id         String        @id @default(cuid())
  categoryId String
  name       String
  sortOrder  Int           @default(0)

  category StockCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([categoryId, name])
}
