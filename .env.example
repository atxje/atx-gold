# Database - PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL="postgresql://username:password@localhost:5432/leadmanagement?schema=public"

# NextAuth.js Configuration
NEXTAUTH_URL="http://localhost:3000"
# Generate a secure secret with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-key-here"

# Google OAuth & APIs (for Calendar sync and Gmail monitoring)
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Twilio SMS Configuration
# Get credentials at: https://www.twilio.com/console
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_PHONE_NUMBER="+1234567890"

# Anthropic Claude API for AI features
# Get your API key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=""

# Cron job secret for scheduled tasks (daily reminders)
# Generate with: openssl rand -base64 32
CRON_SECRET=""
